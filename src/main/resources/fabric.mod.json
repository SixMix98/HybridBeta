{
  "schemaVersion": 1,
  "id": "hybridbeta",
  "version": "${version}",

  "name": "Hybrid Beta",
  "description": "Adding new and old features to Beta 1.7.3 as well as several improvements",
  "authors": [
    "SixMix"
  ],
  "contact": {
    "homepage": "https://glass-launcher.net/",
    "sources": "https://github.com/calmilamsy/stationapi-example-mod"
  },

  "license": "CC0-1.0",
  "icon": "assets/hybridbeta/icon.png",

  "environment": "*",
  "entrypoints": {
    "stationapi:event_bus": [
      "io.github.SixMix98.hybridbeta.events.init.InitListener",
      "io.github.SixMix98.hybridbeta.events.init.BlockListener",
      "io.github.SixMix98.hybridbeta.events.init.FuelListener",
      "io.github.SixMix98.hybridbeta.events.init.EntityListener",
      "io.github.SixMix98.hybridbeta.events.init.client.EntityRenderers",
      "io.github.SixMix98.hybridbeta.events.init.ItemListener"
    ],
    "stationapi:event_bus_client": [
    ],
    "stationapi:event_bus_server": [
    ]
  },
  "mixins": [
    "hybridbeta.mixins.json"
  ],

  "depends": {
    "minecraft": "1.0.0-beta.7.3"
  },

  "suggests": {
    "retrocommands": "*"
  }
}
